<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spracherkennung"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Powered by Google Speech API"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp"/>

    <!-- Microphone Button -->
    <Button
        android:id="@+id/btnMic"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:text="🎤 Sprechen"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4A90D9"
        android:stateListAnimator="@null"
        android:elevation="6dp"
        android:layout_marginBottom="24dp"/>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bereit – Mikrofon drücken"
        android:textSize="15sp"
        android:textColor="#555555"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="32dp"/>

    <!-- History Button -->
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📋 Verlauf anzeigen"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6C757D"
        android:stateListAnimator="@null"
        android:paddingHorizontal="24dp"/>

</LinearLayout>
